{
  "name": "plagiarism-coach",
  "version": "0.1.0",
  "description": "Educational plagiarism detection tool that teaches students how to write and cite correctly",
  "main": "dist/cli/index.js",
  "bin": {
    "plagiarism-coach": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanNguyenSi/plagiarism-coach.git"
  },
  "keywords": [
    "plagiarism",
    "education",
    "citation",
    "paraphrasing",
    "academic-writing",
    "cli"
  ],
  "author": "Ice <ice@openclaw.ai>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LanNguyenSi/plagiarism-coach/issues"
  },
  "homepage": "https://github.com/LanNguyenSi/plagiarism-coach#readme",
  "devDependencies": {
    "@types/natural": "^5.1.5",
    "@types/node": "^20.17.15",
    "@vitest/coverage-v8": "^3.0.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "citation-js": "^0.7.19",
    "commander": "^12.1.0",
    "marked": "^15.0.6",
    "natural": "^8.0.1",
    "ora": "^8.1.1"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "yaml": ">=2.8.3"
  }
}
